# Configure a Groq key only if you really want LLM refinement in the browser.
# IMPORTANT: in Vite, variables prefixed with VITE_ are exposed to the client bundle.
# For production, the ideal setup is to move this call to a backend/proxy.
VITE_GROQ_API_KEY=your_groq_key_here
VITE_GROQ_MODEL=llama-3.3-70b-versatile
